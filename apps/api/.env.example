# ── Database ──────────────────────────────────────────────
# Matches docker-compose.yml (bun run db:up)
DATABASE_URL=postgresql://postgres:pass@localhost:5433/hospital_erp

# ── Server ────────────────────────────────────────────────
PORT=3001

# ── LLM (OpenAI-compatible) ───────────────────────────────
# Free option: OpenTyphoon (SCB 10X) — https://opentyphoon.ai
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=https://api.opentyphoon.ai/v1
OPENAI_MODEL=typhoon-v2.1-12b-instruct

# Alternatively OpenAI:
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini
