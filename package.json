{
  "name": "hospital-doc-ai",
  "private": true,
  "workspaces": ["apps/*", "packages/*"],
  "packageManager": "bun@1.3.14",
  "engines": {
    "bun": ">=1.2.0",
    "npm": "bun-is-our-jam",
    "yarn": "bun-is-our-jam",
    "pnpm": "bun-is-our-jam"
  },
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "test:e2e": "bun run --filter=@app/web test:e2e",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:generate": "bun run --filter=@app/api db:generate",
    "db:migrate": "bun run --filter=@app/api db:migrate",
    "db:push": "bun run --filter=@app/api db:push",
    "db:studio": "bun run --filter=@app/api db:studio",
    "clean": "git clean -xdf node_modules .turbo"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "turbo": "^2.3.3",
    "typescript": "^5.7.3"
  }
}
